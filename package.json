{
  "name": "nodejs-user-management-short-take-home",
  "version": "1.0.0",
  "description": "CRUD user API with OpenWeatherMap location enrichment and a React frontend",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:setup": "bash scripts/setup-rtdb.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "web:install": "npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "build": "npm run web:install && npm run web:build"
  },
  "dependencies": {
    "compression": "1.8.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "firebase-admin": "14.2.0",
    "pino": "10.3.1",
    "tz-lookup": "6.1.25",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.10",
    "nodemon": "3.1.14",
    "supertest": "7.2.2",
    "vitest": "4.1.10"
  },
  "keywords": []
}
