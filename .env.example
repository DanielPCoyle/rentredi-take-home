# --- Server -----------------------------------------------------------------
PORT=8080
LOG_LEVEL=info

# --- Analytics (optional) ----------------------------------------------------
# Google Analytics 4 Measurement ID. When set, the frontend loads gtag.js and
# tracks page views + events (user_created / user_updated / user_deleted,
# theme_toggle, location_select). Absent -> no analytics is loaded.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- OpenWeatherMap ----------------------------------------------------------
# Get a free key at https://openweathermap.org/api. This is a secret — never commit a real one.
OWM_API_KEY=your_openweathermap_api_key_here
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
OWM_TIMEOUT_MS=5000
DEFAULT_COUNTRY=US
# Set to 1 to bypass OpenWeatherMap with deterministic data (used by e2e tests).
OWM_MOCK=0

# --- Database ----------------------------------------------------------------
# Default driver is an in-memory store (zero setup). To use Firebase Realtime
# Database (the bonus), uncomment DB_DRIVER and provide the admin credential.
# DB_DRIVER=firebase
# FIREBASE_DATABASE_URL=https://<project>-default-rtdb.firebaseio.com
# Admin credential: a path to a service-account JSON file, OR the JSON inline.
# FIREBASE_SERVICE_ACCOUNT=./service-account.json

# --- Frontend live sync (ReactFire) ------------------------------------------
# Public web config handed to the browser so ReactFire can subscribe to the
# Realtime Database directly. Present -> UI shows live updates; absent -> polls.
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=<project>.firebaseapp.com
# FIREBASE_PROJECT_ID=<project>
# FIREBASE_APP_ID=
# FIREBASE_MESSAGING_SENDER_ID=
